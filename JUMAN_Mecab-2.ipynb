    "            norm = unicodedata.normalize('NFKC', surface)\n",
    "            \n",
    "            all_tokens_mecab.append(norm)\n",
    "            all_pos_mecab.append(pos)         \n",
    "            \n",
    "            if norm.isdigit():\n",
