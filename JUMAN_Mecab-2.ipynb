   "id": "d84afb9e-7ade-4e9d-8664-4933b07b7257",
   "metadata": {},
   "outputs": [],
   "source": [
    "def avg_token_length(tokens):\n",
    "    return sum(len(t) for t in tokens) / len(tokens)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "759d1452-ffe7-4d59-8535-4961d170970d",
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_boundaries(tokens):\n",
    "    boundaries = set()\n",
    "    pos = 0\n",
    "    for tok in tokens[:-1]:\n",
    "        pos += len(tok)\n",
    "        boundaries.add(pos)\n",
    "    return boundaries"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "671056a7-779d-4ccc-8f08-1ec16180f9bc",
   "metadata": {},
   "outputs": [],
   "source": [
    "def boundary_metrics(tokens1, tokens2):\n",
    "    b1 = get_boundaries(tokens1)\n",
    "    b2 = get_boundaries(tokens2)\n",
    "    \n",
    "    tp = len(b1 & b2) \n",
    "    fp = len(b2 - b1)\n",
    "    fn = len(b1 - b2)\n",
    "    \n",
    "    precision = tp / (tp + fp) if tp + fp else 0\n",
    "    recall = tp / (tp + fn) if tp + fn else 0\n",
    "    f1 = (2 * precision * recall / (precision + recall)\n",
    "          if precision + recall else 0)\n",
    "    \n",
    "    return precision, recall, f1"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b4db3211-945c-4cff-ac43-607c7f8e0e0d",
   "metadata": {},
   "outputs": [],
   "source": [
    "def token_agreement(tokens1, tokens2):\n",
    "    set1 = set(tokens1)\n",
    "    set2 = set(tokens2)\n",
    "    \n",
    "    intersection = len(set1 & set2)\n",
    "    union = len(set1 | set2)\n",
    "    \n",
    "    return intersection / union if union != 0 else 0"
   ]
  },
